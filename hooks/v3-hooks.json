{
  "description": "V3 minimal hooks — PolicyEngine + session snapshot",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "flowctl policy check-hook --tool \"$TOOL_NAME\" 2>/dev/null || true",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "flowctl session snapshot 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
